INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT=http://localhost:9001/api/social/callback/instagram

ALLOW_ADMIN_ENDPOINTS=1

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT=

# For local UI testing: set to false to use real LLMs
LLM_MOCK=false

