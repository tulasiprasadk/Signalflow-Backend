PORT=9001
# Example Database URL (replace credentials)
DATABASE_URL="postgresql://postgres:<DB_PASSWORD>@localhost:5432/social_automation"
REDIS_URL=redis://localhost:6379
# Replace with a strong secret for JWT
JWT_SECRET=<YOUR_JWT_SECRET>

LLM_API_URL=http://localhost:9001/api/core/llm-proxy
LLM_API_KEY=local_dev_key
OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=
UNSPLASH_ACCESS_KEY=
YOUTUBE_API_KEY=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT=http://localhost:9001/api/social/callback/facebook

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
